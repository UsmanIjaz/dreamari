# ───────────────────────────────────────────────────────────────
# Dreamari API — environment variables
#
#   Local dev:   cp .env.example .env     (the defaults below already work
#                with the Dockerized Postgres in docker-compose.yml)
#   Production:  set these in Railway → API service → Variables
# ───────────────────────────────────────────────────────────────

# Postgres connection string.
#   • Local  → the Dockerized Postgres (host port 5434, see docker-compose.yml)
#   • Railway → reference the Postgres plugin:  ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://postgres:dreamari@localhost:5434/dreamari?schema=public"

# Secret that signs Better Auth sessions. MUST be a long random value in prod.
#   • Generate one:  openssl rand -base64 32
BETTER_AUTH_SECRET="dev-better-auth-secret-change-me"

# The API's own public base URL (Better Auth uses it to build URLs).
#   • Local   → http://localhost:8080
#   • Railway → your generated domain, e.g. https://dreamari-api.up.railway.app
API_URL="http://localhost:8080"

# Trusted browser origins for the two web apps (Better Auth CSRF + cookies).
# Sign-in fails with "Invalid origin" if the app's URL isn't listed here.
#   • Local dev:
WEB_ORIGIN="http://localhost:5173"     # student app
ADMIN_ORIGIN="http://localhost:5174"   # admin app
#   • Production → your Vercel URLs, e.g.
#       WEB_ORIGIN="https://dreamari-student.vercel.app"
#       ADMIN_ORIGIN="https://dreamari-admin.vercel.app"

# Resend — transactional email (invite links, password reset, verification).
#   • Get a key at https://resend.com → API Keys
#   • EMAIL_FROM defaults to Resend's sandbox sender, which needs no domain but
#     only delivers to your own Resend account email. Use a verified domain
#     (e.g. "Dreamari <noreply@yourdomain>") to reach real student inboxes.
#   • Invite links are built from WEB_ORIGIN above.
RESEND_API_KEY=""
EMAIL_FROM="Dreamari <onboarding@resend.dev>"

# Port to listen on. Railway injects PORT automatically — leave it unset there.
PORT=8080

# In production also set:
#   NODE_ENV=production      # makes Better Auth issue Secure (HTTPS-only) cookies
