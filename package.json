{
  "name": "dreamari",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "description": "Dreamari — career discovery platform. Monorepo: one backend, many clients.",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "api": "pnpm --filter @dreamari/api dev",
    "student": "pnpm --filter @dreamari/student dev",
    "admin": "pnpm --filter @dreamari/admin dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild"]
  }
}
